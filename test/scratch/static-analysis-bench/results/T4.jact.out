            },
            {
              "type": "paragraph",
              "raw": " /** Delegate to formatValidationResult.formatAsJSON. */\n private formatAsJSON(result: ValidationResult): string {\n     return formatAsJSON(result);\n }",
              "text": " /** Delegate to formatValidationResult.formatAsJSON. */\n private formatAsJSON(result: ValidationResult): string {\n     return formatAsJSON(result);\n }",
              "tokens": [
                {
                  "type": "text",
                  "raw": " /** Delegate to formatValidationResult.formatAsJSON. */\n private formatAsJSON(result: ValidationResult): string {\n     return formatAsJSON(result);\n }",
                  "text": " /** Delegate to formatValidationResult.formatAsJSON. */\n private formatAsJSON(result: ValidationResult): string {\n     return formatAsJSON(result);\n }",
