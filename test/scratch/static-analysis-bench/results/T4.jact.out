              "raw": "\n\n"
            },
            {
              "type": "paragraph",
              "raw": " /** Delegate to formatValidationResult.formatForCLI. */\n private formatForCLI(\n     result: ValidationResult & { lineRange?: string },\n     nestedCodeblockWarnings: NestedCodeblockWarning[] = [],\n     verbose = false,\n ): string {\n     return formatForCLI(result, nestedCodeblockWarnings, verbose);\n }",
              "text": " /** Delegate to formatValidationResult.formatForCLI. */\n private formatForCLI(\n     result: ValidationResult & { lineRange?: string },\n     nestedCodeblockWarnings: NestedCodeblockWarning[] = [],\n     verbose = false,\n ): string {\n     return formatForCLI(result, nestedCodeblockWarnings, verbose);\n }",
              "tokens": [
                {
                  "type": "text",
                  "raw": " /** Delegate to formatValidationResult.formatForCLI. */\n private formatForCLI(\n     result: ValidationResult & { lineRange?: string },\n     nestedCodeblockWarnings: NestedCodeblockWarning[] = [],\n     verbose = false,\n ): string {\n     return formatForCLI(result, nestedCodeblockWarnings, verbose);\n }",
                  "text": " /** Delegate to formatValidationResult.formatForCLI. */\n private formatForCLI(\n     result: ValidationResult & { lineRange?: string },\n     nestedCodeblockWarnings: NestedCodeblockWarning[] = [],\n     verbose = false,\n ): string {\n     return formatForCLI(result, nestedCodeblockWarnings, verbose);\n }",
                  "escaped": false
